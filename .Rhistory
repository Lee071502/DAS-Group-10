# 1. Prepare Log-transformed Data
df_clean <- df_clean %>%
mutate(log_votes = log1p(votes))
# 2. Density Plot for Raw Votes (Likely very squashed)
p_raw_density <- ggplot(df_clean, aes(x = votes, fill = is_high_rating_factor)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = c("#d95f02", "#1b9e77")) +
labs(title = "Density Plot of Raw Votes",
x = "Total Votes", y = "Density") +
theme_minimal()
# 3. Density Plot for Log-transformed Votes (Much clearer!)
#
p_log_density <- ggplot(df_clean, aes(x = log_votes, fill = is_high_rating_factor)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = c("#d95f02", "#1b9e77")) +
labs(title = "Density Plot of Log-transformed Votes",
x = "Log(Votes + 1)", y = "Density") +
theme_minimal()
# Arrange side-by-side
grid.arrange(p_raw_density, p_log_density, ncol = 1)
